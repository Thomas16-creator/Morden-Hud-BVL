-- ====================== DRAG ======================
local dragging = false
local dragInput, dragStart, startPos

TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = Main.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

TopBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        dragInput = input
    end
end)

UIS.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

-- ====================== TECLA (CONFIGURÁVEL) ======================
UIS.InputBegan:Connect(function(input, gameProcessed)
    -- Captura nova tecla se estiver ouvindo
    if listeningForKey then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            currentKey = input.KeyCode
            keyDisplay.Text = input.KeyCode.Name
            listeningForKey = false
            changeKeyBtn.Text = "Alterar tecla"
            changeKeyBtn.BackgroundColor3 = Color3.fromRGB(0, 80, 130)
        end
        return
    end

    if gameProcessed then return end

    if input.KeyCode == currentKey then
        guiVisible = not guiVisible

        if guiVisible then
            Main.Visible = true
            TweenService:Create(Main, TweenInfo.new(0.25), {
                Position = UDim2.fromScale(0.5, 0.5)
            }):Play()
        else
            TweenService:Create(Main, TweenInfo.new(0.25), {
                Position = UDim2.new(0.5, 0, -1, 0)
            }):Play()
            task.delay(0.25, function()
                if not guiVisible then Main.Visible = false end
            end)
        end
    end
end)
