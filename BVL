-- ====================== STAMINA VARS ======================
local enabled = false
local staminaCache = {}
local updateThread = nil

local function findAndCacheStamina()
    staminaCache = {}

    pcall(function()
        Player:SetAttribute("Stamina", math.huge)
        Player:SetAttribute("MaxStamina", math.huge)
        staminaCache[#staminaCache+1] = {type = "attribute", parent = Player}
    end)

    for _, v in ipairs(Player:GetDescendants()) do
        if (v:IsA("NumberValue") or v:IsA("IntValue")) then
            local name = v.Name:lower()
            if name:find("stam") or name:find("energ") or name:find("power") or name:find("endur") then
                v.Value = math.huge
                staminaCache[#staminaCache+1] = {type = "value", obj = v}
            end
        end
    end
end

local function startInfiniteLoop()
    updateThread = task.spawn(function()
        while enabled do
            for _, entry in ipairs(staminaCache) do
                if entry.type == "value" and entry.obj then
                    entry.obj.Value = math.huge
                elseif entry.type == "attribute" then
                    pcall(function()
                        Player:SetAttribute("Stamina", math.huge)
                        Player:SetAttribute("MaxStamina", math.huge)
                    end)
                end
            end
            task.wait(0.25)
        end
    end)
end

-- ====================== JUMP VARS ======================
local jumpEnabled = false
local jumpHeight = 10.5

local function applyJump()
    local char = Player.Character or Player.CharacterAdded:Wait()
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.UseJumpPower = false
        humanoid.JumpHeight = jumpHeight
    end
end

local function resetJump()
    local char = Player.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.UseJumpPower = false
            humanoid.JumpHeight = 7.2
        end
    end
end

-- ====================== ESP VARS ======================
local espEnabled = false
local espObjects = {}

local function createESP(character, playerName)
    if espObjects[playerName] then return end

    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.FillColor = Color3.fromRGB(255, 50, 50)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.Adornee = character
    highlight.Parent = character

    local billboardGui = Instance.new("BillboardGui")
    billboardGui.Name = "ESP_Label"
    billboardGui.Size = UDim2.fromOffset(100, 30)
    billboardGui.StudsOffset = Vector3.new(0, 3, 0)
    billboardGui.AlwaysOnTop = true
    billboardGui.Parent = character

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.fromScale(1, 1)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = Color3.new(1, 1, 1)
    nameLabel.TextStrokeTransparency = 0
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 13
    nameLabel.Text = playerName
    nameLabel.Parent = billboardGui

    espObjects[playerName] = {highlight = highlight, billboard = billboardGui}
end

local function removeESP(playerName)
    if espObjects[playerName] then
        pcall(function()
            espObjects[playerName].highlight:Destroy()
            espObjects[playerName].billboard:Destroy()
        end)
        espObjects[playerName] = nil
    end
end

local function enableESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Player and p.Character then
            createESP(p.Character, p.Name)
        end
    end

    Players.PlayerAdded:Connect(function(p)
        if not espEnabled then return end
        p.CharacterAdded:Connect(function(char)
            if not espEnabled then return end
            task.wait(0.5)
            createESP(char, p.Name)
        end)
    end)

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Player then
            p.CharacterAdded:Connect(function(char)
                if not espEnabled then return end
                task.wait(0.5)
                createESP(char, p.Name)
            end)
        end
    end
end

local function disableESP()
    for _, p in ipairs(Players:GetPlayers()) do
        removeESP(p.Name)
    end
    espObjects = {}
end

