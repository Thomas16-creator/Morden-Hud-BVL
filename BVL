        TweenService:Create(toggle, TweenInfo.new(0.15), {
            BackgroundColor3 = state
                and Color3.fromRGB(0, 170, 255)
                or Color3.fromRGB(60, 60, 60)
        }):Play()

        if callback then callback(state) end
    end)
end

local function createSlider(parent, text, minVal, maxVal, defaultVal, callback)
    local holder = Instance.new("Frame")
    holder.Size = UDim2.new(1, -10, 0, 60)
    holder.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
    holder.Parent = parent

    Instance.new("UICorner", holder)

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -10, 0, 20)
    label.Position = UDim2.fromOffset(10, 5)
    label.BackgroundTransparency = 1
    label.Text = text .. ": " .. defaultVal
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = Enum.Font.Gotham
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = holder

    local barBg = Instance.new("Frame")
    barBg.Size = UDim2.new(1, -80, 0, 8)
    barBg.Position = UDim2.new(0, 10, 0, 35)
    barBg.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    barBg.Parent = holder
    Instance.new("UICorner", barBg)

    local barFill = Instance.new("Frame")
    barFill.Size = UDim2.new((defaultVal - minVal) / (maxVal - minVal), 0, 1, 0)
    barFill.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    barFill.Parent = barBg
    Instance.new("UICorner", barFill)

    local input = Instance.new("TextBox")
    input.Size = UDim2.fromOffset(55, 24)
    input.Position = UDim2.new(1, -65, 0, 28)
    input.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    input.TextColor3 = Color3.new(1, 1, 1)
    input.Font = Enum.Font.Gotham
    input.TextSize = 13
    input.Text = tostring(defaultVal)
    input.Parent = holder
    Instance.new("UICorner", input)

    local currentVal = defaultVal

    local function setValue(val)
        val = math.clamp(tonumber(val) or currentVal, minVal, maxVal)
        val = math.floor(val * 10) / 10
        currentVal = val
        label.Text = text .. ": " .. val
        input.Text = tostring(val)
        barFill.Size = UDim2.new((val - minVal) / (maxVal - minVal), 0, 1, 0)
        if callback then callback(val) end
    end

    local sliding = false

    barBg.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = true
        end
    end)

    barBg.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = false
        end
    end)

    UIS.InputChanged:Connect(function(inp)
        if sliding and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local barPos = barBg.AbsolutePosition.X
            local barSize = barBg.AbsoluteSize.X
            local relative = math.clamp((inp.Position.X - barPos) / barSize, 0, 1)
            local newVal = minVal + (maxVal - minVal) * relative
            setValue(newVal)
        end
    end)

    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = false
        end
    end)

    input.FocusLost:Connect(function()
        setValue(input.Text)
    end)
end

